# Fatora Firebase / Hosting configuration
# Copy this file to .env.local and fill values from Firebase Console > Project settings > Web app.

VITE_APP_NAME=Fatora
VITE_APP_NAME_AR=فوترة
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: keep Clerk enabled while Firebase Auth migration is in progress.
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL=
